# SafeVisionAI chatbot service environment template
# Copy to .env and replace placeholders with your real values.

ENVIRONMENT=development
CHATBOT_SERVICE_NAME=SafeVisionAI Chatbot Service
CHATBOT_SERVICE_PORT=8010
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Main backend connection for tools
MAIN_BACKEND_BASE_URL=http://localhost:8000
MAIN_BACKEND_TIMEOUT_SECONDS=20

# Cache and retrieval
REDIS_URL=YOUR_REDIS_URL
CHROMA_PERSIST_DIR=./data/chroma_db
RAG_DATA_DIR=./data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K_RETRIEVAL=5

# Primary / fallback providers
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama3-70b-8192
GROQ_API_KEY=YOUR_GROQ_API_KEY
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GITHUB_TOKEN=YOUR_GITHUB_MODELS_TOKEN
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
TOGETHER_API_KEY=YOUR_TOGETHER_API_KEY
NVIDIA_NIM_API_KEY=YOUR_NVIDIA_NIM_API_KEY
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
HF_TOKEN=YOUR_HUGGING_FACE_TOKEN
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Weather and routing
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_UNITS=metric
OPENROUTESERVICE_API_KEY=YOUR_OPENROUTESERVICE_API_KEY

# General HTTP behavior
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT="RoadSoS/1.0 (replace-with-your-email-or-site)"
