# SafeVisionAI — Git line ending normalization
# Prevents LF/CRLF conflicts between Windows dev and Linux CI/Render

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly LF (backend, workflows, config)
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
*.env.example text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf
Makefile    text eol=lf

# Frontend
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Binary — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.gz        binary
*.onnx      binary
*.bin       binary
*.pkl       binary
*.db        binary
